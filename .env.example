APP_NAME=MacMarket-Trader
ENVIRONMENT=dev
LOG_LEVEL=INFO

# backend runtime (.env at repo root)
DATABASE_URL=sqlite:///./macmarket_trader.db
AUDIT_PERSISTENCE_ENABLED=true
RISK_DOLLARS_PER_TRADE=1000
COMMISSION_PER_TRADE=0
COMMISSION_PER_CONTRACT=0.65
MAX_PORTFOLIO_HEAT=0.06
MAX_POSITION_NOTIONAL=0.20
CORS_ALLOWED_ORIGINS=["http://127.0.0.1:9500","http://localhost:9500"]

# LLM explanation/research layer (optional)
# Default is mock/offline: no API key is required for local or test startup.
# OpenAI can explain recommendations and Opportunity Intelligence memos only.
# Deterministic engines still own approval, entry, stop, target, sizing,
# risk-calendar gate decisions, and paper order creation.
LLM_ENABLED=false
LLM_PROVIDER=mock
LLM_MODEL=gpt-5.1
OPENAI_API_KEY=
# Backward-compatible legacy key name; prefer OPENAI_API_KEY for OpenAI.
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_OUTPUT_TOKENS=1200
LLM_TEMPERATURE=0.2

# auth provider selection (mock|clerk)
# Deployment/prod default: Clerk.
AUTH_PROVIDER=clerk
CLERK_JWT_ISSUER=https://your-clerk-issuer.example.com
CLERK_JWKS_URL=https://your-clerk-issuer.example.com/.well-known/jwks.json
CLERK_JWT_AUDIENCE=
CLERK_SECRET_KEY=
CLERK_API_BASE_URL=https://api.clerk.com
REQUIRE_MFA_FOR_ADMIN=true
ENFORCE_GLOBAL_MFA=false

# Local dev only (explicit opt-in):
# ENVIRONMENT=local
# AUTH_PROVIDER=mock

# email provider selection (console|resend)
EMAIL_PROVIDER=console
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@macmarket-trader.local
# Display name shown in the inbox "From" field: "MacMarket Trader <noreply@...>"
BRAND_FROM_NAME=MacMarket Trader

# Brand logo URL for email templates (leave blank to use embedded base64 asset instead).
# Self-hosted at the Next.js /brand/ static path. The PNG file ships in
# apps/web/public/brand/ and is also embedded as base64 in email_templates.py
# as a deeper fallback if the URL fails to load.
BRAND_LOGO_URL=https://macmarket.io/brand/square_console_ticks_lockup_light.png

# Public URL of the console — used in outbound emails (approval, invite).
# Update to your hosted domain when deploying externally.
CONSOLE_URL=http://localhost:9500


# ── Market data provider ─────────────────────────────────────────────────────
#
# Polygon.io (preferred live provider):
#   Set POLYGON_ENABLED=true and add a valid POLYGON_API_KEY for live market data.
#   Free Starter tier (https://polygon.io/dashboard/signup) supports delayed bars
#   and snapshots — sufficient for research-preview analysis and replay.
#   Leave POLYGON_ENABLED=false to use deterministic demo fallback instead.
#
# Demo fallback (default):
#   POLYGON_ENABLED=false + WORKFLOW_DEMO_FALLBACK=true allows full workflow
#   on deterministic generated bars — for local dev and UI testing only.
#
# Alpaca (alternate scaffold, not the primary path):
#   Set MARKET_DATA_PROVIDER=alpaca and MARKET_DATA_ENABLED=true with Alpaca keys.
#
MARKET_DATA_PROVIDER=fallback
MARKET_DATA_ENABLED=false
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_MARKET_DATA_FEED=iex
# Alpaca paper trading endpoint — used by AlpacaBrokerProvider (Phase 9). The
# API keys above (APCA_API_KEY_ID / APCA_API_SECRET_KEY) work for both
# market data and paper trading. BROKER_PROVIDER stays "mock" until Phase 9
# wires the live paper broker.
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
MARKET_DATA_REQUEST_TIMEOUT_SECONDS=8
MARKET_DATA_LATEST_CACHE_TTL_SECONDS=10
MARKET_DATA_HISTORICAL_CACHE_TTL_SECONDS=120

# Polygon.io live market data — opt in by setting POLYGON_ENABLED=true
# Get a free API key at: https://polygon.io/dashboard/signup
POLYGON_ENABLED=false
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io
POLYGON_TIMEOUT_SECONDS=8

# deterministic recommendation quality gates
MIN_EXPECTED_RR=1.4
MAX_EVENT_CONTINUATION_VOLATILITY=0.045
MIN_CATALYST_SOURCE_QUALITY_SCORE=0.0
