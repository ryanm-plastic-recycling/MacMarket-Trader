APP_NAME=MacMarket-Trader
ENVIRONMENT=dev
LOG_LEVEL=INFO

# backend runtime (.env at repo root)
DATABASE_URL=sqlite:///./macmarket_trader.db
AUDIT_PERSISTENCE_ENABLED=true
RISK_DOLLARS_PER_TRADE=1000
MAX_PORTFOLIO_HEAT=0.06
MAX_POSITION_NOTIONAL=0.20
CORS_ALLOWED_ORIGINS=["http://127.0.0.1:9500","http://localhost:9500"]

# auth provider selection (mock|clerk)
AUTH_PROVIDER=mock
CLERK_JWT_ISSUER=https://your-clerk-issuer.example.com
CLERK_JWKS_URL=https://your-clerk-issuer.example.com/.well-known/jwks.json
CLERK_JWT_AUDIENCE=
CLERK_SECRET_KEY=
CLERK_API_BASE_URL=https://api.clerk.com
REQUIRE_MFA_FOR_ADMIN=true
ENFORCE_GLOBAL_MFA=false

# email provider selection (console|resend)
EMAIL_PROVIDER=console
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@macmarket-trader.local

# deterministic recommendation quality gates
MIN_EXPECTED_RR=1.4
MAX_EVENT_CONTINUATION_VOLATILITY=0.045
MIN_CATALYST_SOURCE_QUALITY_SCORE=0.0
